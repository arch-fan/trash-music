{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Trash Music",
  "version": "0.1.0",
  "identifier": "com.archfan.trashmusic",
  "build": {
    "devUrl": "https://music.youtube.com/",
    "frontendDist": "https://music.youtube.com/"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "main",
        "title": "Trash Music",
        "width": 1440,
        "height": 960,
        "minWidth": 960,
        "minHeight": 640,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
